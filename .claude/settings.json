{
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/statusline.js"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task|Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/plan-guard.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
